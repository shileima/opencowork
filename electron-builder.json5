// @see - https://www.electron.build/configuration/configuration
{
  "$schema": "https://raw.githubusercontent.com/electron-userland/electron-builder/master/packages/app-builder-lib/scheme.json",
  "appId": "com.qacowork.app",
  "asar": true,
  "productName": "QACowork",

  "directories": {
    "output": "release/${version}"
  },
  "publish": {
    "provider": "github",
    "owner": "shileima",
    "repo": "opencowork"
  },
  "npmRebuild": false,
  "buildDependenciesFromSource": false,
  "files": [
    "dist",
    "dist-electron",
    // node-pty 是 native module，在 vite 中被标记为 external，
    // 运行时通过 createRequire 动态加载，必须随 app 一起打包
    "node_modules/node-pty/**/*"
  ],
  // native .node 文件无法从 asar 归档中加载，必须解压到 app.asar.unpacked
  "asarUnpack": [
    "node_modules/node-pty/**/*.node",
    "node_modules/node-pty/build/**/*",
    "node_modules/node-pty/prebuilds/**/*"
  ],
  "extraResources": [
    {
      "from": "public/icon.png",
      "to": "icon.png"
    },
    // 美团内部私有包（@mtfe/sso-web-oidc-cli 及其依赖），内置以免外部安装
    {
      "from": "resources/node_modules",
      "to": "node_modules",
      "filter": "**/*"
    },
    {
      "from": "resources/skills",
      "to": "skills",
      "filter": "**/*"
    },
    {
      "from": "resources/templates",
      "to": "templates",
      "filter": "**/*"
    },
    {
      "from": "resources/mcp",
      "to": "mcp",
      "filter": "**/*"
    },
    {
      "from": "resources/admin-users.json",
      "to": "admin-users.json"
    },
    {
      "from": "resources/node",
      "to": "node",
      "filter": ["**/*"]
    },
    // Playwright 包（JS）
    {
      "from": "resources/playwright/package",
      "to": "playwright/package",
      "filter": ["**/*"]
    },
    // Chromium 压缩包（由 scripts/pack-chromium.mjs 生成）
    // 避免将数百个 Chromium 小文件交给 codesign 逐一签名（会导致构建失败）
    // 应用首次启动时自动解压到 userData playwright/browsers/
    {
      "from": "resources/playwright/chromium.tar.gz",
      "to": "playwright/chromium.tar.gz"
    }
  ],
  "mac": {
    "target": [
      "dmg",
      "zip"
    ],
    "artifactName": "${productName}-Mac-${version}-Installer.${ext}",
    "hardenedRuntime": true,
    "gatekeeperAssess": false,
    "entitlements": "build/entitlements.mac.plist",
    "entitlementsInherit": "build/entitlements.mac.plist",
    "icon": "resources/icons/icon.icns",
    "category": "public.app-category.productivity",
    // osx-sign 会把 locale.pak 当作二进制并逐文件 codesign，部分环境会报
    // "A timestamp was expected but was not found" 或 SIGSEGV；跳过这些资源文件
    // @see https://github.com/electron-userland/electron-builder/issues/6796
    "signIgnore": [
      "\\.lproj/locale\\.pak$"
    ]
  },
  "dmg": {
    "icon": "resources/icons/icon.icns",
    "contents": [
      {
        "x": 130,
        "y": 220
      },
      {
        "x": 410,
        "y": 220,
        "type": "link",
        "path": "/Applications"
      }
    ]
  },
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": [
          "x64"
        ]
      },
      {
        "target": "portable",
        "arch": [
          "x64"
        ]
      }
    ],
    "icon": "resources/icons/icon.ico"
  },
  "nsis": {
    "oneClick": false,
    "perMachine": false,
    "allowToChangeInstallationDirectory": true,
    "deleteAppDataOnUninstall": false,
    "artifactName": "${productName}-Windows-${version}-Setup.${ext}"
  },
  "portable": {
    "artifactName": "${productName}-Windows-${version}-Portable.${ext}"
  },
  "linux": {
    "target": [
      "AppImage",
      "deb"
    ],
    "maintainer": "shileima <mashilei@meituan.com>",
    "category": "Utility",
    "icon": "public/icon.png",
    "artifactName": "${productName}-Linux-${version}.${ext}"
  }
}
